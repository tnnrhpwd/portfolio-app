{
  "name": "csimple-addon",
  "version": "1.0.8",
  "description": "CSimple AI Addon — Local AI assistant with system tray integration",
  "main": "main.js",
  "author": "tnnrhpwd",
  "license": "MIT",
  "scripts": {
    "start": "node scripts/dev-start.js",
    "dev": "node scripts/dev-start.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:install": "node scripts/build-and-install.js",
    "update:local": "powershell -ExecutionPolicy Bypass -File scripts/install-local-update.ps1",
    "release": "node release.js",
    "test:unit": "node server/automation/recorder/compiler.test.js && node server/automation/recorder/generalize.test.js && node server/automation/recorder/infer-params.test.js && node server/automation/recorder/scrub.test.js && node server/automation/capability-summary.test.js && node server/automation/events.test.js && node server/automation/triggers.test.js && node server/automation/planner.test.js && node server/automation/skill-hotkeys.test.js && node server/automation/nl-compiler.test.js && node server/automation/predictor.test.js && node server/automation/tools/input.test.js && node server/automation/permissions.test.js && node server/automation/tools/skill.test.js && node server/automation/vision-fusion.test.js && node server/automation/llm-provider.test.js && node server/automation/eval/runner.test.js",
    "eval": "node server/automation/eval/cli.js",
    "eval:dry": "node server/automation/eval/cli.js --dry",
    "test": "npm run test:unit && npm run eval",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "multer": "^2.0.2",
    "playwright-core": "^1.60.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.csimple.addon",
    "productName": "CSimple Addon",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "tray.js",
      "auto-updater.js",
      "python-manager.js",
      "server/**/*",
      "scripts/**/*",
      "resources/**/*",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CSimple Addon",
      "runAfterFinish": true,
      "include": "build/installer.nsh",
      "warningsAsErrors": false
    },
    "portable": {
      "artifactName": "CSimple-Addon-${version}-portable.exe"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tnnrhpwd",
        "repo": "portfolio-app",
        "releaseType": "release"
      }
    ]
  }
}
