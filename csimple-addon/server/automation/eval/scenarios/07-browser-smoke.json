{
  "name": "browser opens, navigates, reads text, closes",
  "description": "End-to-end smoke test: launches headless Chromium via Edge (or Chrome) channel, navigates to a tiny data: URL, reads the page text, screenshots the page metadata, and closes the session.",
  "require": { "platform": "win32" },
  "permissions": {
    "categories": { "safe-read": "allow", "sandboxed-write": "allow" }
  },
  "steps": [
    {
      "tool": "browser_open",
      "args": { "headless": true, "profile": "csimple-eval" },
      "expect": {
        "ok": true,
        "resultPath": "opened",
        "resultEquals": true,
        "durationMsLte": 30000
      }
    },
    {
      "tool": "browser_goto",
      "args": { "url": "data:text/html,<title>csimple-eval-title</title><h1 id=hello>csimple-eval-hello</h1>" },
      "expect": {
        "ok": true,
        "resultPath": "title",
        "resultContains": "csimple-eval-title",
        "durationMsLte": 15000
      }
    },
    {
      "tool": "browser_text",
      "args": { "selector": "#hello" },
      "expect": {
        "ok": true,
        "resultPath": "text",
        "resultContains": "csimple-eval-hello"
      }
    },
    {
      "tool": "browser_screenshot",
      "args": { "returnInline": false },
      "expect": {
        "ok": true,
        "resultPath": "mime",
        "resultEquals": "image/png"
      }
    },
    {
      "tool": "browser_close",
      "args": {},
      "expect": {
        "ok": true,
        "resultPath": "closed",
        "resultEquals": true
      }
    }
  ]
}
